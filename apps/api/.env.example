# ── Backend environment variables ────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.

# Port the Fastify server listens on
PORT=3001

# Allowed CORS origin (frontend URL)
# WARNING: do NOT set this to "*" — that allows any website to call this API.
# For local dev, use the exact Next.js dev URL.
CORS_ORIGIN=http://localhost:3000

# SweetBook API credentials
# Get these from the SweetBook developer dashboard
SWEETBOOK_API_KEY=sk_test_replace_me
# Sandbox (assignment / testing): https://api-sandbox.sweetbook.com/v1
# Live (production):               https://api.sweetbook.com/v1
SWEETBOOK_BASE_URL=https://api-sandbox.sweetbook.com/v1

# Set to "true" to skip real SweetBook calls and return mock data.
# Use this for local development when you don't have a real API key.
SWEETBOOK_MOCK=true

# Public base URL of this API server.
# Used to construct the URL returned by POST /api/v1/uploads.
# Change this if you expose the server on a non-default port or hostname.
BASE_URL=http://localhost:3001
