# ── Backend environment variables ────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.

# Port the Fastify server listens on
PORT=3001

# Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3000

# SweetBook API credentials
# Get these from the SweetBook developer dashboard
SWEETBOOK_API_KEY=sk_test_replace_me
SWEETBOOK_BASE_URL=https://api.sweetbook.io/v1

# Set to "true" to skip real SweetBook calls and return mock data.
# Use this for local development when you don't have a real API key.
SWEETBOOK_MOCK=true
