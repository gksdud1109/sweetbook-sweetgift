# ── Root .env.example ─────────────────────────────────────────────────────────
# Copy this to .env (or to apps/api/.env) and fill in real values.
# NEVER commit real secrets.

# ── Backend (apps/api) ────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000
SWEETBOOK_API_KEY=sk_test_replace_me
# Sandbox (assignment / testing): https://api-sandbox.sweetbook.com/v1
# Live (production):               https://api.sweetbook.com/v1
SWEETBOOK_BASE_URL=https://api-sandbox.sweetbook.com/v1
# Set to "true" for local dev without a real SweetBook key.
# 심사 시 실제 API 연동이 어려운 경우 "true"로 두어 mock 흐름을 테스트할 수 있습니다.
SWEETBOOK_MOCK=false

# API 서버의 공개 주소 (업로드 파일 URL 생성 시 사용)
BASE_URL=http://localhost:3001

# ── Frontend (apps/web) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
